<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: #e2e8f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .container { padding: 2rem; width: 100%; max-width: 600px; }
    .card {
      background: rgba(30, 41, 59, 0.8);
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 16px;
      padding: 3rem;
      text-align: center;
      backdrop-filter: blur(10px);
    }
    h1 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(90deg, #34d399, #38bdf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .subtitle { color: #94a3b8; margin-bottom: 2rem; }
    .badge {
      display: inline-block;
      background: rgba(52, 211, 153, 0.2);
      color: #34d399;
      padding: 0.35rem 1rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 2rem;
    }
    .info {
      text-align: left;
      background: rgba(15, 23, 42, 0.5);
      border-radius: 10px;
      padding: 1.5rem;
      margin-top: 1rem;
    }
    .info h2 {
      font-size: 1rem;
      color: #94a3b8;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .info ul { list-style: none; }
    .info li { padding: 0.4rem 0; font-size: 0.95rem; }
    .info code {
      background: rgba(52, 211, 153, 0.2);
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.85rem;
    }
    .footer-note { color: #64748b; font-size: 0.8rem; margin-top: 1.5rem; }
    .endpoints { margin-top: 1.5rem; }
    .endpoints a {
      display: inline-block;
      color: #38bdf8;
      text-decoration: none;
      margin: 0.3rem 0.5rem;
      font-size: 0.9rem;
    }
    .endpoints a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1><%= title %></h1>
      <p class="subtitle">Server-Side Rendered &middot; Express + EJS</p>
      <span class="badge">Server is Running</span>

      <div class="info">
        <h2>Server Info</h2>
        <ul>
          <li><strong>Render Mode:</strong> SSR (Server-Side)</li>
          <li><strong>Framework:</strong> Express 4</li>
          <li><strong>Template Engine:</strong> EJS</li>
          <li><strong>Node Version:</strong> <code><%= nodeVersion %></code></li>
          <li><strong>Port:</strong> <code><%= port %></code></li>
          <li><strong>Environment:</strong> <code><%= env %></code></li>
          <li><strong>PID:</strong> <code><%= pid %></code></li>
          <li><strong>Memory:</strong> <code><%= memoryUsage %> MB</code></li>
        </ul>
      </div>

      <div class="endpoints">
        <a href="/health">/health</a>
        <a href="/api/info">/api/info</a>
      </div>

      <p class="footer-note">
        Page rendered at: <%= new Date().toISOString() %>
      </p>
    </div>
  </div>
</body>
</html>
